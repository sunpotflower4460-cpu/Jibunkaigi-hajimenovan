# Firebase client config for optional cloud save.
# Do not put service account keys here.
# These values are public Firebase web app config values, but should be managed per environment.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API server-side secret.
# Do NOT prefix with VITE_.
# Register this only in Vercel Environment Variables or equivalent server-side secrets.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
